APP_NAME=Guardrail Gateway
APP_ENV=development
FRONTEND_ORIGINS=http://localhost:5173
# Production (Render): set to your Vercel URL, e.g. https://guardrail-gateway.vercel.app
DATA_DIR=
# Render free tier: /tmp/guardrail-data (ephemeral across deploys)

# Chat providers (mock works without keys)
OPENAI_API_KEY=
GEMINI_API_KEY=
# Grok (xAI) — default chat + prompt scanning when set
XAI_API_KEY=
# Alias also accepted:
# GROK_API_KEY=

DEFAULT_PROVIDER=auto
LLM_TIMEOUT_SEC=60

# Production: set API_KEY and mirror it in Vercel as VITE_GATEWAY_API_KEY
API_KEY=
REQUIRE_API_KEY=false
RATE_LIMIT_CHAT_PER_MIN=30
STORE_FULL_LOG_CONTENT=false

# Prompt scanning: auto prefers Grok (if key set) → HF DistilBERT → sklearn
ML_GUARD_ENABLED=true
ML_GUARD_BACKEND=auto
ML_GUARD_MODEL=fmops/distilbert-prompt-injection
ML_GUARD_GROK_MODEL=grok-3-mini
ML_GUARD_GROK_BLOCK_THRESHOLD=0.75
ML_GUARD_GROK_WARN_THRESHOLD=0.55