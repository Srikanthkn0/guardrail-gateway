APP_NAME=Guardrail Gateway
APP_ENV=development
FRONTEND_ORIGINS=http://localhost:5173
# Production (Render): set to your Vercel URL, e.g. https://guardrail-gateway.vercel.app
DATA_DIR=
# Render free tier: /tmp/guardrail-data (ephemeral across deploys)

# Providers (mock works without keys)
OPENAI_API_KEY=
GROQ_API_KEY=
DEFAULT_PROVIDER=auto
LLM_TIMEOUT_SEC=60